---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

// Folder under /public/images that holds the photo example galleries.
const PHOTO_DIR = 'Photos';
const getExampleImagePath = (dir: string, slug: string, image: string) =>
  `/images/${dir}/${slug}/${image}`;

const packs = [
  {
    id: 'photo',
    label: 'Photo',
    price: 1000,
    mediaType: 'photo',
    description:
      'Photos illimitées pendant votre soutenance : moments spontanés, photos avec la famille, les amis, les invités et séance extérieure moderne.',
    examples: [
      { title: 'Photos spontanées',      desc: 'Dans la salle de soutenance', slug: 'spontanees', images: ['DSC03507.jpg', 'DSC03523.jpg', 'DSC03556.jpg', 'DSC05961.jpg', 'DSC06570.jpg', 'DSC06631.jpg'] },
      { title: 'Photos avec les parents', desc: 'Souvenirs familiaux',        slug: 'parents',    images: ['DSC01021.jpg', 'DSC04364.jpg', 'DSC04566.jpg', 'DSC06152.jpg', 'DSC06245.jpg', 'DSC06380.jpg'] },
      { title: 'Photos avec les invités', desc: 'Moments partagés',           slug: 'invites',    images: ['DSC03055.jpg', 'DSC04236.jpg', 'DSC04282.jpg', 'DSC04578.jpg', 'DSC04676.jpg', 'DSC07814.jpg'] },
      { title: 'Photos de groupe',        desc: 'Avec les amis',              slug: 'groupe',     images: ['_DSC8889.jpg', 'DSC04195.jpg', 'DSC042011.jpg', 'DSC04573.jpg', 'DSC04922.jpg', 'DSC08041.jpg'] },
      { title: 'Séance extérieure',       desc: 'Poses modernes',             slug: 'exterieure', images: ['DSC03203.jpg', 'DSC03697.jpg', 'DSC03736.jpg'] },
      { title: 'Portraits individuels',   desc: 'En tenue de graduation',     slug: 'portraits',  images: ['DSC02138.jpg', 'DSC03035.jpg', 'DSC03093.jpg'] },
    ],
  },
  {
    id: 'video',
    label: 'Vidéo intégrale',
    price: 500,
    mediaType: 'video',
    description:
      'Enregistrement complet de votre présentation, des remarques du jury et du serment.',
    examples: [
      { title: 'Présentation complète', desc: 'Du début à la fin' },
      { title: 'Questions du jury',     desc: 'Enregistrées en intégral' },
      { title: 'Remarques du jury',     desc: 'Feedback officiel' },
      { title: 'Serment',              desc: 'Moment solennel' },
      { title: 'Ambiance salle',       desc: 'Atmosphère réelle' },
      { title: 'Souvenir complet',     desc: 'À revoir plus tard' },
    ],
  },
  {
    id: 'bestof',
    label: 'Best Of cinématique',
    price: 1000,
    mediaType: 'video',
    description:
      "Une vidéo courte, émotionnelle et dynamique qui résume les meilleurs moments de votre journée.",
    examples: [
      { title: "Arrivée à l'école",  desc: "Plans d'entrée" },
      { title: 'Préparation',        desc: 'Avant soutenance' },
      { title: 'Moments famille',    desc: 'Émotion pure' },
      { title: 'Applaudissements',   desc: 'La récompense' },
      { title: 'Plans extérieur',    desc: 'Style cinématique' },
      { title: 'Vidéo finale',       desc: 'Prête à partager' },
    ],
  },
  {
    id: 'reel',
    label: 'Reel cinématique',
    price: 200,
    mediaType: 'reel',
    description:
      'Une vidéo verticale courte et moderne, idéale pour Instagram, TikTok ou WhatsApp.',
    examples: [
      { title: 'Format vertical',   desc: '9:16 natif' },
      { title: 'Plans dynamiques',  desc: 'Rapides et modernes' },
      { title: 'Musique tendance',  desc: 'Ambiance actuelle' },
      { title: 'Transitions',      desc: 'Effets modernes' },
      { title: 'Stories ready',    desc: 'Instagram / TikTok' },
      { title: 'Livraison rapide', desc: 'Facile à partager' },
    ],
  },
];
---

<BaseLayout
  title="Réserver votre soutenance | Framers Graduation Maroc"
  description="Réservez votre couverture de soutenance avec Framers. Choisissez vos services photo ou vidéo et confirmez votre date."
>
  <!-- Sticky nav -->
  <header class="sticky top-0 z-50 border-b border-[#E6E6E6] bg-white/95 backdrop-blur-sm">
    <nav
      class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex items-center justify-between"
      aria-label="Navigation principale"
    >
      <a
        href="/"
        class="font-display text-xl font-bold tracking-widest uppercase text-[#050505]"
        style="font-family: 'Playfair Display', serif;"
        aria-label="Framers — Retour à l'accueil"
      >
        Framers
      </a>
      <div class="flex items-center gap-6">
        <a href="/" class="hidden md:block text-sm text-[#777777] hover:text-[#050505] transition-colors duration-200">
          Accueil
        </a>
        <a href="/#services" class="hidden md:block text-sm text-[#777777] hover:text-[#050505] transition-colors duration-200">
          Services
        </a>
        <a href="#booking-form" class="btn-primary px-5 py-2 rounded-full text-sm tracking-wide">
          Réserver
        </a>
      </div>
    </nav>
  </header>

  <main>

    <!-- 1. Hero -->
    <section class="py-20 md:py-28 px-6 md:px-12 bg-white text-center border-b border-[#E6E6E6]">
      <div class="max-w-3xl mx-auto">
        <p class="text-xs font-semibold tracking-[0.3em] uppercase mb-5 text-[#777777]">
          Réservation
        </p>
        <h1
          class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-[#050505] leading-[1.1] mb-6"
          style="font-family: 'Playfair Display', serif;"
        >
          Réservez votre couverture<br class="hidden sm:block" /> de soutenance
        </h1>
        <div class="section-divider mt-6 mb-8"></div>
        <p class="text-[#777777] text-base md:text-lg leading-relaxed mb-5 max-w-2xl mx-auto">
          Découvrez nos services, sélectionnez ceux qui correspondent à votre journée, puis
          envoyez-nous vos informations pour confirmer la disponibilité.
        </p>
        <p class="text-sm font-medium text-[#2A2A2A] tracking-wide">
          Photos, vidéos et souvenirs premium pour votre graduation au Maroc.
        </p>
      </div>
    </section>

    <!-- 2. Service discovery -->
    <section class="py-20 md:py-28 px-6 md:px-12 bg-[#F8F8F5]" aria-labelledby="discovery-heading">
      <div class="max-w-5xl mx-auto">

        <div class="text-center mb-14">
          <p class="text-xs font-semibold tracking-[0.3em] uppercase mb-4 text-[#777777]">
            Nos services
          </p>
          <h2
            id="discovery-heading"
            class="font-display text-3xl md:text-4xl font-bold text-[#050505]"
            style="font-family: 'Playfair Display', serif;"
          >
            Qu'est-ce qui est inclus dans chaque service ?
          </h2>
          <div class="section-divider mt-6 mb-0"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {packs.map((pack) => (
            <article
              class="card-hover bg-[#FDFDFB] border border-[#E6E6E6] rounded-2xl p-6 flex flex-col"
              aria-label={`Service ${pack.label}`}
            >
              <!-- Header -->
              <div class="flex items-start justify-between mb-1">
                <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#777777]">
                  {pack.label}
                </p>
                <span class="text-xl font-bold text-[#050505]">
                  {pack.price} <span class="text-sm font-normal text-[#777777]">MAD</span>
                </span>
              </div>

              {pack.id === 'reel' && (
                <p class="text-xs text-[#777777] italic mb-3">
                  Disponible uniquement avec le Best Of cinématique.
                </p>
              )}

              <div class="h-px bg-[#E6E6E6] mt-3 mb-4"></div>

              <p class="text-sm text-[#777777] leading-relaxed mb-5">
                {pack.description}
              </p>

              <!-- Media slider -->
              <div class="mb-6">
                <p class="text-xs font-semibold text-[#777777] tracking-[0.15em] uppercase mb-3">
                  Exemples inclus
                </p>
                <div class="overflow-x-auto scrollbar-hide">
                  <div class="flex gap-3 pb-1">
                    {pack.examples.map((ex) => (
                      <div
                        class={`shrink-0 rounded-xl overflow-hidden border border-[#E6E6E6] shadow-sm bg-white ${
                          pack.mediaType === 'reel' ? 'w-24' : pack.mediaType === 'photo' ? 'w-32' : 'w-36'
                        } ${pack.mediaType === 'photo' && ex.images?.length ? 'gallery-trigger cursor-pointer group' : ''}`}
                        {...(pack.mediaType === 'photo' && ex.images?.length
                          ? { role: 'button', tabindex: '0', 'data-gallery-slug': ex.slug, 'aria-label': `Voir les photos : ${ex.title}` }
                          : {})}
                      >
                        {/* Thumbnail */}
                        {pack.mediaType === 'photo' ? (
                          ex.images?.length ? (
                            <div class="relative h-20 bg-[#EBEBEB] overflow-hidden">
                              <img
                                src={getExampleImagePath(PHOTO_DIR, ex.slug, ex.images[0])}
                                alt={ex.title}
                                loading="lazy"
                                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                              />
                              <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/30 transition-colors duration-200">
                                <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-white text-xs font-semibold tracking-wide flex items-center gap-1">
                                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                  Voir
                                </span>
                              </div>
                              <span class="absolute top-1.5 right-1.5 text-[10px] font-semibold text-white bg-black/55 rounded-full px-1.5 py-0.5 leading-none">
                                {ex.images.length}
                              </span>
                            </div>
                          ) : (
                            <div class="h-20 bg-[#EBEBEB] flex items-center justify-center">
                              <svg class="w-7 h-7" style="color: #AAAAAA;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
                              </svg>
                            </div>
                          )
                        ) : pack.mediaType === 'reel' ? (
                          <div class="h-32 flex flex-col items-center justify-center gap-1.5" style="background: #111111;">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background: rgba(255,255,255,0.18);">
                              <svg class="w-3.5 h-3.5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z"/>
                              </svg>
                            </div>
                            <span class="text-xs font-mono" style="color: rgba(255,255,255,0.4);">9:16</span>
                          </div>
                        ) : (
                          <div class="h-20 flex items-center justify-center" style="background: #111111;">
                            <div class="w-9 h-9 rounded-full flex items-center justify-center" style="background: rgba(255,255,255,0.18);">
                              <svg class="w-4 h-4 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z"/>
                              </svg>
                            </div>
                          </div>
                        )}
                        {/* Info */}
                        <div class="p-2.5">
                          <p class="text-xs font-semibold text-[#050505] leading-tight truncate">
                            {ex.title}
                          </p>
                          <p class="text-xs text-[#777777] mt-0.5 leading-tight truncate">
                            {ex.desc}
                          </p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Toggle CTA -->
              <button
                type="button"
                class="btn-primary w-full py-3 rounded-xl text-sm font-semibold tracking-wide transition-all duration-200 mt-auto"
                data-toggle-service={pack.id}
                aria-label={`Ajouter le service ${pack.label}`}
              >
                Ajouter ce service
              </button>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. Booking form -->
    <section id="booking-form" class="py-20 md:py-28 px-6 md:px-12 bg-white" aria-labelledby="form-heading">
      <div class="max-w-3xl mx-auto">

        <div class="text-center mb-14">
          <p class="text-xs font-semibold tracking-[0.3em] uppercase mb-4 text-[#777777]">
            Vos informations
          </p>
          <h2
            id="form-heading"
            class="font-display text-3xl md:text-4xl font-bold text-[#050505]"
            style="font-family: 'Playfair Display', serif;"
          >
            Confirmer ma réservation
          </h2>
          <div class="section-divider mt-6 mb-0"></div>
        </div>

        <form id="reservation-form" novalidate class="flex flex-col gap-8">

          <!-- Personal details -->
          <div class="flex flex-col gap-5">

            <div>
              <label for="fullName" class="form-label">Nom complet <span aria-hidden="true">*</span></label>
              <input type="text" id="fullName" name="fullName" required autocomplete="name"
                placeholder="Votre nom et prénom" class="form-input" />
              <p class="form-error hidden" data-error="fullName">Ce champ est requis.</p>
            </div>

            <div>
              <label for="school" class="form-label">École / Université <span aria-hidden="true">*</span></label>
              <input type="text" id="school" name="school" required autocomplete="organization"
                placeholder="Ex : ENSIAS, Université Hassan II, ISCAE..." class="form-input" />
              <p class="form-error hidden" data-error="school">Ce champ est requis.</p>
            </div>

            <div>
              <label for="phone" class="form-label">Numéro de téléphone <span aria-hidden="true">*</span></label>
              <input type="tel" id="phone" name="phone" required autocomplete="tel"
                placeholder="06XXXXXXXX" class="form-input" />
              <p class="form-error hidden" data-error="phone">Ce champ est requis.</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="defenseDate" class="form-label">Date de soutenance <span aria-hidden="true">*</span></label>
                <input type="date" id="defenseDate" name="defenseDate" required class="form-input" />
                <p class="form-error hidden" data-error="defenseDate">Ce champ est requis.</p>
              </div>
              <div>
                <label for="defenseTime" class="form-label">Heure de soutenance <span aria-hidden="true">*</span></label>
                <input type="time" id="defenseTime" name="defenseTime" required class="form-input" />
                <p class="form-error hidden" data-error="defenseTime">Ce champ est requis.</p>
              </div>
            </div>
          </div>

          <!-- Service selection -->
          <div>
            <p class="form-label mb-1">Services choisis <span aria-hidden="true">*</span></p>
            <p class="text-xs text-[#777777] mb-4">Vous pouvez sélectionner plusieurs services.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4" role="group" aria-label="Sélection des services">
              {packs.map((pack) => (
                <div
                  class="service-card rounded-2xl border border-[#E6E6E6] p-5 cursor-pointer transition-all duration-200 hover:shadow-md flex flex-col"
                  data-service-id={pack.id}
                  role="checkbox"
                  aria-checked="false"
                  tabindex="0"
                  aria-label={`${pack.label} — ${pack.price} MAD`}
                >
                  <input type="checkbox" name="services" value={pack.id} class="sr-only" tabindex="-1" />

                  <!-- Top row: check + price -->
                  <div class="flex items-start justify-between mb-3">
                    <div class="check-box w-5 h-5 rounded border-2 border-[#D0D0D0] flex items-center justify-center shrink-0 transition-all duration-200">
                      <svg class="check-icon w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                      </svg>
                    </div>
                    <div class="text-right">
                      <span class="service-price text-sm font-bold text-[#050505]">{pack.price} MAD</span>
                    </div>
                  </div>

                  <!-- Title -->
                  <h3 class="font-semibold text-[#050505] text-base mb-1 leading-snug">{pack.label}</h3>

                  {pack.id === 'reel' && (
                    <p class="text-xs text-[#777777] italic mb-2">
                      Requiert le Best Of cinématique.
                    </p>
                  )}

                  <p class="text-xs text-[#777777] leading-relaxed mb-4">{pack.description}</p>

                  <!-- Media slider (stopPropagation prevents accidental card toggle) -->
                  <!-- <div class="slider-area mt-auto">
                    <p class="text-xs font-semibold text-[#777777] tracking-[0.15em] uppercase mb-2">
                      Exemples inclus
                    </p>
                    <div class="overflow-x-auto scrollbar-hide">
                      <div class="flex gap-2.5 pb-1">
                        {pack.examples.map((ex) => (
                          <div
                            class={`shrink-0 rounded-xl overflow-hidden border border-[#E6E6E6] shadow-sm bg-white ${
                              pack.mediaType === 'reel' ? 'w-20' : pack.mediaType === 'photo' ? 'w-28' : 'w-32'
                            }`}
                          >
                            {pack.mediaType === 'photo' ? (
                              <div class="h-16 bg-[#EBEBEB] flex items-center justify-center">
                                <svg class="w-6 h-6" style="color: #AAAAAA;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
                                </svg>
                              </div>
                            ) : pack.mediaType === 'reel' ? (
                              <div class="h-28 flex flex-col items-center justify-center gap-1" style="background: #111111;">
                                <div class="w-7 h-7 rounded-full flex items-center justify-center" style="background: rgba(255,255,255,0.18);">
                                  <svg class="w-3 h-3 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M8 5v14l11-7z"/>
                                  </svg>
                                </div>
                                <span class="text-xs font-mono" style="color: rgba(255,255,255,0.4);">9:16</span>
                              </div>
                            ) : (
                              <div class="h-16 flex items-center justify-center" style="background: #111111;">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background: rgba(255,255,255,0.18);">
                                  <svg class="w-3.5 h-3.5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M8 5v14l11-7z"/>
                                  </svg>
                                </div>
                              </div>
                            )}
                            <div class="p-2">
                              <p class="text-xs font-semibold text-[#050505] leading-tight truncate">{ex.title}</p>
                              <p class="text-xs text-[#777777] mt-0.5 leading-tight truncate">{ex.desc}</p>
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div> -->
                </div>
              ))}
            </div>

            <!-- Reel dependency warning -->
            <div id="reel-warning" class="hidden mt-3 rounded-xl border border-[#E6E6E6] bg-[#F8F8F5] px-4 py-3 flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-[#2A2A2A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
              </svg>
              <p class="text-xs text-[#2A2A2A] leading-relaxed">
                Le Reel est disponible uniquement avec le Best Of cinématique.
              </p>
            </div>

            <p class="form-error hidden mt-3" data-error="services">
              Veuillez sélectionner au moins un service.
            </p>

            <!-- Dynamic total -->
            <div id="price-display" class="mt-5 rounded-xl px-5 py-5 transition-all duration-300">
              <p id="promo-msg" class="promo-msg text-xs mb-1.5"></p>
              <p id="total-price" class="text-sm"></p>
            </div>
          </div>

          <!-- Optional info -->
          <div>
            <label for="optionalInfo" class="form-label">Informations facultatives</label>
            <textarea
              id="optionalInfo"
              name="optionalInfo"
              rows="4"
              placeholder="Précisions sur le lieu, demandes spéciales, nombre de personnes attendues..."
              class="form-input resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="pt-1">
            <button type="submit" class="btn-primary w-full py-4 rounded-xl text-base font-bold tracking-wide">
              Envoyer ma demande de réservation
            </button>
            <p class="text-xs text-[#777777] text-center mt-4 leading-relaxed">
              Nous confirmerons la disponibilité de votre date dans les 24 heures.
            </p>
          </div>

        </form>

        <!-- Success state -->
        <div
          id="success-msg"
          class="hidden mt-8 rounded-2xl border border-[#E6E6E6] bg-[#F8F8F5] px-8 py-14 text-center"
          role="alert"
          aria-live="polite"
        >
          <div class="w-12 h-12 rounded-full bg-[#050505] flex items-center justify-center mx-auto mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <p class="font-display text-2xl font-bold text-[#050505] mb-2" style="font-family: 'Playfair Display', serif;">
            Demande envoyée !
          </p>
          <p class="text-sm text-[#777777] leading-relaxed max-w-xs mx-auto">
            Nous vous contacterons dans les 24 heures pour confirmer votre date de soutenance.
          </p>
          <a href="/" class="inline-block mt-8 text-sm font-semibold text-[#050505] underline underline-offset-4">
            Retour à l'accueil
          </a>
        </div>

      </div>
    </section>

    <!-- 4. Photo gallery lightbox -->
    <div
      id="gallery-modal"
      class="hidden fixed inset-0 z-[100] items-center justify-center"
      role="dialog"
      aria-modal="true"
      aria-labelledby="gallery-title"
    >
      <!-- Backdrop -->
      <div id="gallery-backdrop" class="absolute inset-0 bg-black/85 backdrop-blur-sm"></div>

      <!-- Content -->
      <div class="relative z-10 w-full h-full md:h-auto md:max-w-4xl md:max-h-[92vh] flex flex-col mx-auto md:my-6 px-4 md:px-0">

        <!-- Header -->
        <div class="flex items-start justify-between gap-4 py-4 md:py-3 shrink-0">
          <div class="min-w-0">
            <h3 id="gallery-title" class="text-white font-display text-lg md:text-xl font-bold truncate" style="font-family: 'Playfair Display', serif;"></h3>
            <p id="gallery-desc" class="text-white/60 text-sm truncate"></p>
          </div>
          <button
            type="button"
            id="gallery-close"
            class="shrink-0 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors"
            aria-label="Fermer la galerie"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- Stage -->
        <div class="relative flex-1 min-h-0 flex items-center justify-center">
          <button
            type="button"
            id="gallery-prev"
            class="absolute left-0 md:-left-4 z-20 w-11 h-11 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition-colors"
            aria-label="Image précédente"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>

          <img
            id="gallery-image"
            src=""
            alt=""
            class="max-w-full max-h-full object-contain rounded-lg select-none"
            draggable="false"
          />

          <button
            type="button"
            id="gallery-next"
            class="absolute right-0 md:-right-4 z-20 w-11 h-11 rounded-full bg-white/10 hover:bg-white/25 text-white flex items-center justify-center transition-colors"
            aria-label="Image suivante"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

        <!-- Counter -->
        <p id="gallery-counter" class="text-center text-white/70 text-sm font-mono py-3 shrink-0"></p>

        <!-- Thumbnails -->
        <div id="gallery-thumbs" class="flex gap-2 overflow-x-auto scrollbar-hide pb-4 justify-start md:justify-center shrink-0"></div>
      </div>
    </div>

  </main>

  <Footer />

  <style>
    /* ── Form elements ─────────────────────── */
    .form-label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: #050505;
      margin-bottom: 0.5rem;
    }
    .form-input {
      width: 100%;
      border-radius: 0.75rem;
      border: 1px solid #E6E6E6;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      color: #050505;
      background: #ffffff;
      outline: none;
      transition: border-color 0.2s ease;
      font-family: inherit;
    }
    .form-input::placeholder { color: #777777; }
    .form-input:focus { border-color: #050505; }
    .form-input.error { border-color: #f87171; }
    .form-error { margin-top: 0.375rem; font-size: 0.75rem; color: #ef4444; }

    /* ── Slider ────────────────────────────── */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

    /* ── Service cards ─────────────────────── */
    .service-card { outline: none; }
    .service-card:focus-visible { box-shadow: 0 0 0 3px rgba(5,5,5,0.15); }
    .service-card .check-icon { opacity: 0; transition: opacity 0.15s; }
    .service-card.selected {
      border-color: #050505;
      background-color: #F8F8F5;
      box-shadow: 0 2px 12px rgba(5,5,5,0.08);
    }
    .service-card.selected .check-box { background-color: #050505; border-color: #050505; }
    .service-card.selected .check-icon { opacity: 1; }

    /* ── Price display ─────────────────────── */
    #price-display { border: 1px solid #E6E6E6; background: #F8F8F5; }
    #total-price { color: #777777; }
    .promo-msg { display: none; color: rgba(255,255,255,0.65); }

    #price-display.has-total { border-color: #050505; background: #050505; }
    #price-display.has-total #total-price { color: #ffffff; font-weight: 700; font-size: 1rem; }
    #price-display.has-total .promo-msg { display: block; }
  </style>

  <script define:vars={{ packs, PHOTO_DIR }}>
    /* ── Config ──────────────────────────────────────────────────────────
       Edit these to update pricing rules without touching the logic below.
    ─────────────────────────────────────────────────────────────────────── */
    const promotion = {
      enabled: true,
      type: 'free_reel_when_all_selected',
      freeServiceId: 'reel',
      requiredServiceIds: ['photo', 'video', 'bestof', 'reel'],
    };

    const REEL_ID   = 'reel';
    const BESTOF_ID = 'bestof';
    /* ─────────────────────────────────────────────────────────────────── */

    const priceMap = Object.fromEntries(packs.map((p) => [p.id, p.price]));
    const labelMap = Object.fromEntries(packs.map((p) => [p.id, p.label]));
    const selectedServices = new Set();
    let reelWarningTimer = null;

    /* ── Promo calculation ───────────────────── */
    function isPromoActive() {
      return (
        promotion.enabled &&
        promotion.requiredServiceIds.every((id) => selectedServices.has(id))
      );
    }

    function effectivePrice(packId) {
      if (isPromoActive() && packId === promotion.freeServiceId) return 0;
      return priceMap[packId];
    }

    /* ── Total display ───────────────────────── */
    function updateTotal() {
      const display  = document.getElementById('price-display');
      const totalEl  = document.getElementById('total-price');
      const promoEl  = document.getElementById('promo-msg');
      if (!display || !totalEl) return;

      if (selectedServices.size === 0) {
        display.classList.remove('has-total');
        totalEl.textContent = 'Sélectionnez un ou plusieurs services pour voir le total.';
        if (promoEl) promoEl.textContent = '';
        return;
      }

      const promoApplied = isPromoActive();
      const total = [...selectedServices].reduce((sum, id) => sum + effectivePrice(id), 0);

      display.classList.add('has-total');
      totalEl.textContent = `Total estimé : ${total} MAD`;
      if (promoEl) {
        promoEl.textContent = promoApplied ? 'Promotion appliquée : Reel offert.' : '';
      }
    }

    /* ── Card / button UI sync ───────────────── */
    function setCardUI(packId) {
      const isSelected = selectedServices.has(packId);

      // Form service card
      const card = document.querySelector(`.service-card[data-service-id="${packId}"]`);
      const cb   = card?.querySelector('input[type="checkbox"]');
      if (card) {
        card.classList.toggle('selected', isSelected);
        card.setAttribute('aria-checked', String(isSelected));
      }
      if (cb) cb.checked = isSelected;

      // Discovery toggle button
      const btn = document.querySelector(`[data-toggle-service="${packId}"]`);
      if (btn) {
        if (isSelected) {
          btn.textContent = 'Service sélectionné ✓';
          btn.classList.replace('btn-primary', 'btn-outline');
        } else {
          btn.textContent = 'Ajouter ce service';
          btn.classList.replace('btn-outline', 'btn-primary');
        }
      }
    }

    /* ── Reel warning ────────────────────────── */
    function showReelWarning() {
      const warning = document.getElementById('reel-warning');
      if (!warning) return;
      warning.classList.remove('hidden');
      clearTimeout(reelWarningTimer);
      reelWarningTimer = setTimeout(() => warning.classList.add('hidden'), 4000);
    }

    /* ── Core toggle ─────────────────────────── */
    function toggleService(packId) {
      const isCurrentlySelected = selectedServices.has(packId);

      // Guard: reel requires bestof
      if (packId === REEL_ID && !isCurrentlySelected && !selectedServices.has(BESTOF_ID)) {
        showReelWarning();
        return;
      }

      if (isCurrentlySelected) {
        selectedServices.delete(packId);
        // Cascade: deselect reel when bestof is removed
        if (packId === BESTOF_ID && selectedServices.has(REEL_ID)) {
          selectedServices.delete(REEL_ID);
          setCardUI(REEL_ID);
        }
      } else {
        selectedServices.add(packId);
      }

      setCardUI(packId);
      updateTotal();
      if (selectedServices.size > 0) {
        document.querySelector('[data-error="services"]')?.classList.add('hidden');
      }
    }

    /* ── Discovery buttons ───────────────────── */
    document.querySelectorAll('[data-toggle-service]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.toggleService;
        toggleService(id);
        // Scroll to form only when adding a service (not removing)
        if (selectedServices.has(id)) {
          document.getElementById('booking-form')?.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });

    /* ── Form service cards ──────────────────── */
    document.querySelectorAll('.service-card').forEach((card) => {
      card.addEventListener('click', () => toggleService(card.dataset.serviceId));
      card.addEventListener('keydown', (e) => {
        if (e.key === ' ' || e.key === 'Enter') {
          e.preventDefault();
          toggleService(card.dataset.serviceId);
        }
      });
    });

    // Stop slider clicks from bubbling up to the card toggle
    document.querySelectorAll('.slider-area').forEach((area) => {
      area.addEventListener('click', (e) => e.stopPropagation());
    });

    /* ── Form submit ─────────────────────────── */
    const form       = document.getElementById('reservation-form');
    const successMsg = document.getElementById('success-msg');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      let valid = true;

      ['fullName', 'school', 'phone', 'defenseDate', 'defenseTime'].forEach((id) => {
        const input = document.getElementById(id);
        const error = document.querySelector(`[data-error="${id}"]`);
        if (!input?.value.trim()) {
          valid = false;
          input?.classList.add('error');
          error?.classList.remove('hidden');
        } else {
          input?.classList.remove('error');
          error?.classList.add('hidden');
        }
      });

      if (selectedServices.size === 0) {
        valid = false;
        document.querySelector('[data-error="services"]')?.classList.remove('hidden');
      }

      if (!valid) return;

      const promoApplied = isPromoActive();

      const selectedServicesArr = [...selectedServices].map((id) => ({
        id,
        label:  labelMap[id],
        price:  effectivePrice(id),
        isFree: promoApplied && id === promotion.freeServiceId,
      }));

      const formData = {
        fullName:         document.getElementById('fullName').value.trim(),
        school:           document.getElementById('school').value.trim(),
        phone:            document.getElementById('phone').value.trim(),
        defenseDate:      document.getElementById('defenseDate').value,
        defenseTime:      document.getElementById('defenseTime').value,
        selectedServices: selectedServicesArr,
        totalPrice:       selectedServicesArr.reduce((s, p) => s + p.price, 0),
        promoApplied,
        optionalInfo:     document.getElementById('optionalInfo').value.trim(),
      };

      console.log('[Framers] Réservation soumise :', formData);

      // --- Connecter votre backend ici ---
      //
      // Option 1 — n8n webhook :
      // fetch('https://YOUR_N8N_INSTANCE/webhook/reservation', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify(formData),
      // });
      //
      // Option 2 — Airtable API :
      // fetch('https://api.airtable.com/v0/YOUR_BASE_ID/Reservations', {
      //   method: 'POST',
      //   headers: { Authorization: 'Bearer YOUR_TOKEN', 'Content-Type': 'application/json' },
      //   body: JSON.stringify({ fields: formData }),
      // });
      //
      // Option 3 — WhatsApp (Twilio / Meta Cloud API) :
      // fetch('https://your-api.com/whatsapp/send', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify(formData),
      // });
      //
      // Option 4 — API endpoint générique :
      // fetch('/api/reservation', { method: 'POST', body: JSON.stringify(formData) });
      // ------------------------------------

      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
      successMsg?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Live validation clear
    ['fullName', 'school', 'phone', 'defenseDate', 'defenseTime'].forEach((id) => {
      document.getElementById(id)?.addEventListener('input', () => {
        const input = document.getElementById(id);
        const error = document.querySelector(`[data-error="${id}"]`);
        if (input?.value.trim()) {
          input.classList.remove('error');
          error?.classList.add('hidden');
        }
      });
    });

    /* ── Photo gallery lightbox ──────────────── */
    const photoExamples = Object.fromEntries(
      (packs.find((p) => p.id === 'photo')?.examples ?? []).map((ex) => [ex.slug, ex])
    );

    const modal      = document.getElementById('gallery-modal');
    const backdrop   = document.getElementById('gallery-backdrop');
    const titleEl    = document.getElementById('gallery-title');
    const descEl     = document.getElementById('gallery-desc');
    const imageEl    = document.getElementById('gallery-image');
    const counterEl  = document.getElementById('gallery-counter');
    const thumbsEl   = document.getElementById('gallery-thumbs');
    const closeBtn   = document.getElementById('gallery-close');
    const prevBtn    = document.getElementById('gallery-prev');
    const nextBtn    = document.getElementById('gallery-next');

    let currentExample = null;
    let currentIndex   = 0;
    let lastTrigger    = null;

    const imagePath = (slug, image) => `/images/${PHOTO_DIR}/${slug}/${image}`;

    function preloadNeighbours() {
      if (!currentExample) return;
      const { images, slug } = currentExample;
      [currentIndex + 1, currentIndex - 1].forEach((i) => {
        const idx = (i + images.length) % images.length;
        new Image().src = imagePath(slug, images[idx]);
      });
    }

    function renderImage() {
      if (!currentExample || !imageEl) return;
      const { images, slug, title } = currentExample;
      imageEl.src = imagePath(slug, images[currentIndex]);
      imageEl.alt = `${title} — photo ${currentIndex + 1} sur ${images.length}`;
      if (counterEl) counterEl.textContent = `${currentIndex + 1} / ${images.length}`;

      thumbsEl?.querySelectorAll('button').forEach((btn, i) => {
        const active = i === currentIndex;
        btn.classList.toggle('ring-2', active);
        btn.classList.toggle('ring-white', active);
        btn.classList.toggle('opacity-100', active);
        btn.classList.toggle('opacity-50', !active);
        btn.setAttribute('aria-current', String(active));
        if (active) btn.scrollIntoView({ block: 'nearest', inline: 'nearest' });
      });

      preloadNeighbours();
    }

    function renderThumbs() {
      if (!thumbsEl || !currentExample) return;
      thumbsEl.innerHTML = '';
      currentExample.images.forEach((img, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className =
          'shrink-0 w-16 h-12 rounded-md overflow-hidden transition-opacity duration-150 hover:opacity-100';
        btn.setAttribute('aria-label', `Aller à la photo ${i + 1}`);
        const thumb = document.createElement('img');
        thumb.src = imagePath(currentExample.slug, img);
        thumb.alt = '';
        thumb.loading = 'lazy';
        thumb.className = 'w-full h-full object-cover';
        btn.appendChild(thumb);
        btn.addEventListener('click', () => {
          currentIndex = i;
          renderImage();
        });
        thumbsEl.appendChild(btn);
      });
    }

    function openGallery(slug, trigger) {
      const example = photoExamples[slug];
      if (!example?.images?.length || !modal) return;

      currentExample = example;
      currentIndex = 0;
      lastTrigger = trigger ?? null;

      if (titleEl) titleEl.textContent = example.title;
      if (descEl)  descEl.textContent  = example.desc;

      renderThumbs();
      renderImage();

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      closeBtn?.focus();
    }

    function closeGallery() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      if (imageEl) imageEl.src = '';
      currentExample = null;
      currentIndex = 0;
      lastTrigger?.focus();
      lastTrigger = null;
    }

    function showNextImage() {
      if (!currentExample) return;
      currentIndex = (currentIndex + 1) % currentExample.images.length;
      renderImage();
    }

    function showPreviousImage() {
      if (!currentExample) return;
      const len = currentExample.images.length;
      currentIndex = (currentIndex - 1 + len) % len;
      renderImage();
    }

    // Triggers (example cards)
    document.querySelectorAll('.gallery-trigger').forEach((card) => {
      card.addEventListener('click', () => openGallery(card.dataset.gallerySlug, card));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openGallery(card.dataset.gallerySlug, card);
        }
      });
    });

    closeBtn?.addEventListener('click', closeGallery);
    backdrop?.addEventListener('click', closeGallery);
    prevBtn?.addEventListener('click', showPreviousImage);
    nextBtn?.addEventListener('click', showNextImage);

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!currentExample) return;
      if (e.key === 'Escape')     { e.preventDefault(); closeGallery(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); showNextImage(); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); showPreviousImage(); }
    });

    // Touch swipe
    let touchStartX = 0;
    let touchStartY = 0;
    const SWIPE_MIN = 50;

    imageEl?.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].clientX;
      touchStartY = e.changedTouches[0].clientY;
    }, { passive: true });

    imageEl?.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) < SWIPE_MIN || Math.abs(dx) < Math.abs(dy)) return;
      if (dx < 0) showNextImage();
      else showPreviousImage();
    }, { passive: true });

    // Init
    updateTotal();
  </script>

</BaseLayout>
