---
---

<section id="contact" class="py-24 md:py-32 px-6 md:px-12 bg-[#F8F8F5]" aria-labelledby="contact-heading">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: Info -->
      <div>
        <p class="text-xs font-semibold tracking-[0.3em] uppercase mb-4 text-[#777777]">Réservations</p>
        <h2 id="contact-heading" class="font-display text-4xl md:text-5xl font-bold text-[#050505] mb-5 leading-tight" style="font-family: 'Playfair Display', serif;">
          Réservez votre date
        </h2>
        <div class="section-divider mt-0 mb-8 ml-0" style="margin-left: 0;"></div>
        <p class="text-[#777777] text-base leading-relaxed mb-10">
          Laissez vos informations et notre équipe vous contactera rapidement pour organiser votre couverture graduation.
        </p>

        <!-- Info items -->
        <div class="flex flex-col gap-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl border border-[#E6E6E6] bg-white flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-[#2A2A2A]" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[#050505] font-medium text-sm">Disponible partout au Maroc</p>
              <p class="text-[#777777] text-xs mt-1">Casablanca, Rabat, Marrakech, Fès, Tanger et plus</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl border border-[#E6E6E6] bg-white flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-[#2A2A2A]" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-[#050505] font-medium text-sm">Réponse rapide</p>
              <p class="text-[#777777] text-xs mt-1">Nous vous répondons dans les 24h</p>
            </div>
          </div>
        </div>

        <!-- WhatsApp CTA -->
        <div class="mt-10 p-5 rounded-2xl border border-[#E6E6E6] bg-white">
          <p class="text-[#777777] text-sm mb-3">Vous préférez WhatsApp ? Contactez-nous directement.</p>
          <a
            href="https://wa.me/212600000000"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-semibold text-sm px-5 py-3 rounded-xl border border-[#E6E6E6] bg-[#F8F8F5] text-[#050505] hover:bg-[#050505] hover:text-white hover:border-[#050505] transition-all duration-200"
            aria-label="Contacter Framers sur WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
            Écrire sur WhatsApp
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-white border border-[#E6E6E6] rounded-2xl p-8 md:p-10">
        <form
          id="contact-form"
          class="flex flex-col gap-6"
          novalidate
          aria-label="Formulaire de réservation Framers"
        >
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-medium text-[#2A2A2A] mb-2">
              Nom complet <span class="text-[#050505]" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              placeholder="Ex: Imane Benali"
              class="w-full bg-[#F8F8F5] border border-[#E6E6E6] rounded-xl px-4 py-3.5 text-[#050505] placeholder-[#777777] text-sm outline-none transition-all duration-200 focus:border-[#050505] focus:bg-white"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="phone" class="block text-sm font-medium text-[#2A2A2A] mb-2">
              Numéro de téléphone <span class="text-[#050505]" aria-hidden="true">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              placeholder="Ex: +212 6XX XXX XXX"
              class="w-full bg-[#F8F8F5] border border-[#E6E6E6] rounded-xl px-4 py-3.5 text-[#050505] placeholder-[#777777] text-sm outline-none transition-all duration-200 focus:border-[#050505] focus:bg-white"
            />
          </div>

          <!-- Contact time -->
          <fieldset>
            <legend class="block text-sm font-medium text-[#2A2A2A] mb-3">
              Quand pouvons-nous vous contacter ? <span class="text-[#050505]" aria-hidden="true">*</span>
            </legend>
            <div class="grid grid-cols-2 gap-3">
              {["Matin", "Après-midi", "Soir", "À tout moment"].map((time) => (
                <label class="flex items-center gap-3 p-3.5 rounded-xl border border-[#E6E6E6] bg-[#F8F8F5] cursor-pointer hover:border-[#050505] transition-colors duration-200 has-[:checked]:border-[#050505] has-[:checked]:bg-white">
                  <input
                    type="radio"
                    name="contact_time"
                    value={time}
                    class="sr-only"
                    required
                  />
                  <span class="w-4 h-4 rounded-full border-2 border-[#E6E6E6] flex items-center justify-center flex-shrink-0 transition-colors duration-200" aria-hidden="true">
                    <span class="w-2 h-2 rounded-full bg-[#050505] opacity-0 transition-opacity duration-200 contact-radio-dot"></span>
                  </span>
                  <span class="text-[#2A2A2A] text-sm font-medium">{time}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <!-- Submit -->
          <button
            type="submit"
            class="btn-primary w-full py-4 rounded-xl text-base tracking-wide mt-2"
            aria-label="Envoyer ma demande de réservation"
          >
            Envoyer ma demande
          </button>

          <!-- Error -->
          <p id="form-error" class="text-red-500 text-sm text-center hidden" role="alert">
            Veuillez remplir tous les champs obligatoires.
          </p>
        </form>

        <!-- Success message -->
        <div
          id="form-success"
          class="hidden text-center py-8"
          role="status"
          aria-live="polite"
        >
          <div class="w-16 h-16 rounded-full border-2 border-[#050505] flex items-center justify-center mx-auto mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-7 h-7 text-[#050505]" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="text-[#050505] font-semibold text-xl mb-2" style="font-family: 'Playfair Display', serif;">Merci !</h3>
          <p class="text-[#777777] text-sm leading-relaxed">
            Votre demande a bien été envoyée. Nous vous contacterons bientôt.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  document.querySelectorAll('input[type="radio"][name="contact_time"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.contact-radio-dot').forEach((dot) => {
        (dot as HTMLElement).style.opacity = '0';
      });
      const label = (radio as HTMLElement).closest('label');
      const dot = label?.querySelector('.contact-radio-dot') as HTMLElement | null;
      if (dot) dot.style.opacity = '1';
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg?.classList.add('hidden');

    const nameVal = (form.elements.namedItem('name') as HTMLInputElement)?.value.trim();
    const phoneVal = (form.elements.namedItem('phone') as HTMLInputElement)?.value.trim();
    const timeVal = (form.querySelector('input[name="contact_time"]:checked') as HTMLInputElement)?.value;

    if (!nameVal || !phoneVal || !timeVal) {
      errorMsg?.classList.remove('hidden');
      return;
    }

    // Replace with real webhook URL when ready:
    // await fetch('YOUR_WEBHOOK_URL', { method: 'POST', body: JSON.stringify({ name: nameVal, phone: phoneVal, contact_time: timeVal }), headers: { 'Content-Type': 'application/json' } });

    form.style.display = 'none';
    successMsg?.classList.remove('hidden');
  });
</script>
