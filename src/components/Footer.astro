---

<footer class="border-t border-[#E6E6E6] bg-[#F8F8F5] pt-16 pb-8 px-6 md:px-12" role="contentinfo">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="#hero" class="font-display text-2xl font-bold tracking-widest uppercase text-[#050505]" style="font-family: 'Playfair Display', serif;" aria-label="Framers Graduation — Retour en haut">
          Framers
        </a>
        <p class="text-[#777777] text-sm mt-3 leading-relaxed max-w-xs">
          Photography &amp; Videography for graduation events in Morocco.
        </p>
        <p class="text-[#777777]/70 text-xs mt-4 leading-relaxed">
          Photographe et vidéaste spécialisé dans la soutenance et les cérémonies de remise de diplôme au Maroc : Casablanca, Rabat, Marrakech, Fès, Tanger.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-[#050505] font-semibold text-xs tracking-[0.2em] uppercase mb-5">Navigation</h3>
        <ul class="flex flex-col gap-3" role="list">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[#777777] hover:text-[#050505] text-sm transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-[#050505] font-semibold text-xs tracking-[0.2em] uppercase mb-5">Nous suivre</h3>
        <div class="flex gap-3">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-xl border border-[#E6E6E6] bg-white flex items-center justify-center text-[#777777] hover:text-[#050505] hover:border-[#050505] transition-all duration-200"
              aria-label={`Nous suivre sur ${social.name}`}
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>

        <p class="text-[#777777]/50 text-xs mt-8 leading-loose">
          Photographe graduation Maroc · Vidéo soutenance · Photoshoot graduation Casablanca Rabat
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-[#E6E6E6] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[#777777] text-xs text-center sm:text-left">
        &copy; 2026 Framers. Tous droits réservés.
      </p>
      <div class="w-8 h-px bg-[#E6E6E6]" aria-hidden="true"></div>
    </div>
  </div>
</footer>
