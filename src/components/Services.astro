---

<section id="services" class="py-24 md:py-32 px-6 md:px-12 bg-white" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="text-center mb-16">
      <p class="text-xs font-semibold tracking-[0.3em] uppercase mb-4 text-[#777777]">Ce que nous offrons</p>
      <h2 id="services-heading" class="font-display text-4xl md:text-5xl font-bold text-[#050505] mb-4" style="font-family: 'Playfair Display', serif;">
        Nos services graduation
      </h2>
      <div class="section-divider mt-6 mb-6"></div>
      <p class="text-[#777777] text-base md:text-lg max-w-xl mx-auto leading-relaxed">
        Une couverture complète pour garder chaque détail de votre journée.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((service) => (
        <article
          class="card-hover  bg-[#FDFDFB] border border-[#E6E6E6] rounded-2xl p-8 group"
          aria-label={service.title}
        >
          <!-- Top border highlight on hover -->
          

          <!-- Badge -->
          <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full border border-[#E6E6E6] text-[#777777] bg-[#F8F8F5] mb-6">
            {service.badge}
          </span>

          <!-- Icon -->
          <div class="mb-5 text-[#2A2A2A] transition-colors duration-200 group-hover:text-[#050505]" aria-hidden="true">
            <Fragment set:html={service.icon} />
          </div>

          <!-- Title -->
          <h3 class="font-display text-xl font-semibold text-[#050505] mb-3 leading-snug" style="font-family: 'Playfair Display', serif;">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="text-[#777777] text-sm leading-relaxed">
            {service.description}
          </p>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-14">
      <a href="#contact" class="btn-primary px-10 py-4 rounded-full text-base inline-block" aria-label="Réserver une date pour votre graduation">
        Réserver ma date
      </a>
    </div>
  </div>
</section>
